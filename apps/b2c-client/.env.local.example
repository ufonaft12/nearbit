# ============================================================
# Nearbit – Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# OpenAI
# Used by the direct OpenAI SDK AND picked up automatically by LangChain
OPENAI_API_KEY=sk-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Upstash Redis  (optional — caching + rate limiting disabled gracefully if not set)
# Create a free database at https://console.upstash.com/
# @upstash/redis and @upstash/ratelimit both read these exact variable names
UPSTASH_REDIS_REST_URL=https://<db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# Geolocation API  (ip-api.com free tier — no key required)
# Free tier: 45 req/min. Results are cached in Redis for 24 h, so the limit
# is per unique IP per day — well within limits for normal traffic.
# If you upgrade to a paid plan or switch providers, store the key here:
# IP_API_KEY=your_key_here

# LangChain Tracing  (optional — enables LangSmith observability)
# Lets you see in the LangSmith dashboard why a query was classified as "NO"
# Sign up at https://smith.langchain.com/ to get an API key
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_...
