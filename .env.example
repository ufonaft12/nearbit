# =============================================================================
# Nearbit Platform — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
#
#   cp .env.example .env.local
#
# Variables prefixed NEXT_PUBLIC_* are bundled into the browser bundle at
# build time. All others are server-side only.
# =============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (for migrations & db:types script)
DATABASE_URL=

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Found in: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Optional — caching is disabled gracefully if not set.
# Create a free database at: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Langfuse Tracing ──────────────────────────────────────────────────────────
# Optional — LLM observability for intent checks.
# Sign up at: https://cloud.langfuse.com/
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Geolocation ───────────────────────────────────────────────────────────────
# ip-api.com free tier requires no key. Uncomment if switching to a paid provider:
# IP_API_KEY=

# ── Next.js Apps ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_B2B_APP_URL=http://localhost:3001

# ── Docker Port Mapping (optional overrides) ──────────────────────────────────
B2C_PORT=3000
B2B_PORT=3001

# ── Market Pipeline ───────────────────────────────────────────────────────────
# Comma-separated list of chains to scrape/parse.
# All available: BAREKET,YAYNO_BITAN_AND_CARREFOUR,SHUFERSAL,RAMI_LEVY,VICTORY,HAZI_HINAM,TIV_TAAM
ENABLED_SCRAPERS=BAREKET,YAYNO_BITAN_AND_CARREFOUR,SHUFERSAL
ENABLED_PARSERS=BAREKET,YAYNO_BITAN_AND_CARREFOUR,SHUFERSAL
ENABLED_FILE_TYPES=PRICE_FILE,STORE_FILE
SCRAPER_LIMIT=1
PARSER_LIMIT=1
# Cron schedules — pipeline: :00 scraper → :20 parser → :40 sync
SCRAPER_SCHEDULE_CRON=0 */6 * * *
PARSER_SCHEDULE_CRON=20 */6 * * *
SYNC_SCHEDULE_CRON=40 */6 * * *
PARSER_LOG_LEVEL=INFO

# ── Kaggle ────────────────────────────────────────────────────────────────────
# Found in: kaggle.com → Settings → API → Generate New Token
KAGGLE_API_TOKEN=

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable verbose SQL query logging
SUPABASE_DEBUG=false
