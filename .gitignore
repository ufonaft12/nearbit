# =============================================================================
# Nearbit Platform — .gitignore
# Node.js + Python + Docker + IDE
# =============================================================================

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
!.env.example

# ── Node.js / pnpm ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Next.js ───────────────────────────────────────────────────────────────────
.next/
out/
.vercel
*.tsbuildinfo
next-env.d.ts

# ── TypeScript build output ───────────────────────────────────────────────────
dist/
build/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
.eggs/
*.egg
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
*.pyo
*.pyd

# Poetry
poetry.lock  # Commit this in production; add to .gitignore if you prefer

# ── Docker ────────────────────────────────────────────────────────────────────
# (docker volumes and local override files)
docker-compose.override.yml
.docker/

# ── IDE & Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Supabase ──────────────────────────────────────────────────────────────────
supabase/.temp/
supabase/functions/.cache/

# ── Test & Coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.pid
*.seed
*.pid.lock
.turbo/
